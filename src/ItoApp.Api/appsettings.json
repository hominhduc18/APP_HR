{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "DbProvider": "Postgres",
  "ConnectionStrings": {
    "SqlServer": "Server=localhost\\SQLEXPRESS;Database=AppIto;Trusted_Connection=True;TrustServerCertificate=True;Encrypt=False;",
    "Neon": "YOUR_NEON_POSTGRES_CONNECTION_STRING"
  },
  "Jwt": {
    "Secret": "your-32-character-secret-key-here-change-this",
    "Issuer": "ItoAppAPI",
    "Audience": "ItoAppClient",
    "AccessTokenExpirationMinutes": 15
  },
  "Sms": {
    "Provider": "mock",
    "UseMock": true,
    "Twilio": {
      "AccountSid": "your_account_sid",
      "AuthToken": "your_auth_token",
      "FromNumber": "+1234567890"
    },
    "Vonage": {
      "ApiKey": "your_api_key",
      "ApiSecret": "your_api_secret",
      "FromNumber": "ITOApp"
    },
    "Viettel": {
      "ApiKey": "your_viettel_api_key",
      "SecretKey": "your_viettel_secret",
      "BrandName": "ITOApp",
      "CpCode": "your_cp_code"
    },
    "Mobifone": {
      "Username": "your_username",
      "Password": "your_password",
      "BrandName": "ITOApp"
    },
    "Vinaphone": {
      "ClientId": "your_client_id",
      "ClientSecret": "your_client_secret",
      "Sender": "ITOApp"
    },
    "BrandSms": {
      "ApiKey": "your_api_key",
      "SecretKey": "your_secret_key",
      "BrandName": "ITOApp"
    }
  },
  "Email": {
    "Provider": "mock",
    "UseMock": true,
    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": 587,
      "Username": "your_email@gmail.com",
      "Password": "your_app_password",
      "FromName": "ITO App",
      "FromEmail": "your_email@gmail.com"
    },
    "SendGrid": {
      "ApiKey": "your_sendgrid_api_key",
      "FromName": "ITO App",
      "FromEmail": "your_email@gmail.com"
    }
  },
  "AllowedHosts": "*",
  "Vnpay": {
    "TmnCode": "YOUR_TMN_CODE",
    "HashSecret": "YOUR_HASH_SECRET",
    "BaseUrl": "https://sandbox.vnpayment.vn/paymentv2/vpcpay.html",
    "CallbackUrl": "https://apiito.onrender.com/api/payment/vnpay-return",
    "IpnUrl": "https://apiito.onrender.com/api/payment/vnpay-ipn"
  }
}