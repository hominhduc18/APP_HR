{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth_route": {
        "ClusterId": "identity_cluster",
        "Match": {
          "Path": "api/auth/{**catch-all}"
        }
      },
      "api_route": {
        "ClusterId": "itoapp_api_cluster",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity_cluster": {
        "Destinations": {
          "identity_dest": {
            "Address": "http://localhost:5280"
          }
        }
      },
      "itoapp_api_cluster": {
        "Destinations": {
          "api_dest": {
            "Address": "http://localhost:5270"
          }
        }
      }
    }
  }
}
