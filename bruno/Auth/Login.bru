meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/dang-nhap
  body: json
  auth: none
}

body:json {
  {
    "phone_number": "0901234567",
    "password": "Password123!"
  }
}

script:post-response {
  if (res.status === 200 && res.body.data && res.body.data.token) {
    bru.setEnvVar("accessToken", res.body.data.token);
  }
}
